#!/bin/bash

# The first argument is the file containing the commit message
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Avoid running on automated merges or amended commits if preferred
# But for now, we'll focus on the pattern check
MSG_CONTENT=$(cat "$COMMIT_MSG_FILE")

# Define the regex pattern for "Assisted-by: AI-Tool-Name"
PATTERN="Assisted-by: .+"

if [[ $MSG_CONTENT =~ $PATTERN ]]; then
    # Pattern found, do nothing and proceed
    exit 0
else
    # Pattern not found, redirecting input to terminal to ask user
    exec < /dev/tty
    echo ""
    echo "--- AI Contribution Check ---"
    read -p "Did an AI help author this commit? (y/n): " used_ai

    if [[ "$used_ai" =~ ^[Yy]$ ]]; then
        read -p "Which AI tool? (e.g., Claude, Cursor, Gemini): " ai_tool
        
        if [ -n "$ai_tool" ]; then
            # Append the string to the commit message file
            echo -e "\nAssisted-by: $ai_tool" >> "$COMMIT_MSG_FILE"
            echo "Added: Assisted-by: $ai_tool"
        else
            echo "No tool specified. Proceeding without AI tag."
        fi
    else
        echo "Proceeding with manual authorship."
    fi
fi
