---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: osac-rolebinding
  namespace: {{ osac_operator_ns | default('osac-operator-system') }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: osac
subjects:
  - kind: ServiceAccount
    name: osac-sa
    namespace: {{ aap_ns | default('ansible-aap') }}
