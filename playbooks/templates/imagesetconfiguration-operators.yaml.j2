---
# Operators ImageSet Configuration for Post-Installation Mirroring
# This configuration includes operators and images that will be installed after OpenShift is ready:
# - Operators from defaults/operators.yaml (Quay, ACM, GitOps, etc.)
# - Model operators from defaults/model_operators.yaml
# - Post-install plugin operators (not marked with 'mirror: core')
# - Additional images (Vault, ArgoCD, etc.)
kind: ImageSetConfiguration
apiVersion: mirror.openshift.io/v2alpha1
mirror:
  operators:
    - catalog: {{ certified_operator_catalog }}:{{ certified_operator_catalog_version }}
      packages:
        - name: gpu-operator-certified
          defaultChannel: v25.10
          channels:
            - name: v25.10
              minVersion: 25.10.0
              maxVersion: 25.10.1
    - catalog: {{ rh_operator_catalog }}:{{ rh_operator_catalog_version }}
      packages:
        - name: kubevirt-hyperconverged
{% for operator in operators + model_operators + (_post_install_plugin_operators | default([])) %}
{% set additional_operator_names = operator.csvNames if (operator.csvMirror | default(false) | bool) else [] %}
{% for operator_name in [operator.name] + additional_operator_names %}
        - name: {{ operator_name }}
          defaultChannel: {{ operator.channel }}
          channels:
            - name: {{ operator.channel }}
              minVersion: {{ operator.init_version }}
              maxVersion: {{ operator.version }}
{% endfor %}
{% for pkg in operator.extraMirrorPackages | default([]) %}
        - name: {{ pkg }}
{% endfor %}
{% endfor %}

  additionalImages:
    # Additional images for post-install components
    - name: quay.io/argoproj/argocd:v2.2.2
    - name: registry.connect.redhat.com/hashicorp/vault-csi-provider:1.6.0-ubi
    - name: registry.connect.redhat.com/hashicorp/vault-enterprise:1.20.4-ent-ubi
    - name: registry.connect.redhat.com/hashicorp/vault-k8s:1.7.0-ubi
    - name: registry.connect.redhat.com/hashicorp/vault:1.20.4-ubi

