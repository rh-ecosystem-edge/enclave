---
# OpenShift AI Image Set Configuration
# Mirrors OpenShift AI and supporting operators for disconnected deployments

kind: ImageSetConfiguration
apiVersion: mirror.openshift.io/v2alpha1
mirror:
  operators:
    - catalog: registry.redhat.io/redhat/redhat-operator-index:v{{ mgmt_openshift_version.split('.')[:2] | join('.') }}
      packages:
        # OpenShift AI core operators
        - name: rhods-operator
          defaultChannel: fast-3.x
          channels:
            - name: fast-3.x
              minVersion: 3.0.0
              maxVersion: 3.3.0
        # Node Feature Discovery (required for GPU detection)
        - name: nfd
          defaultChannel: stable
          channels:
            - name: stable
              minVersion: 4.20.0-202509262039
              maxVersion: 4.20.0-202602261925
        # Service Mesh (required for KServe)
        - name: servicemeshoperator3
          defaultChannel: stable
          channels:
            - name: stable
              minVersion: 3.0.0
              maxVersion: 3.2.2
        # Cert Manager (required for TLS)
        - name: openshift-cert-manager-operator
          defaultChannel: stable-v1.18
          channels:
            - name: stable-v1.18
        # Supporting operators
        - name: rhcl-operator
          defaultChannel: stable
          channels:
            - name: stable
              minVersion: 1.3.0
              maxVersion: 1.3.0
        - name: leader-worker-set
          defaultChannel: stable-v1.0
          channels:
            - name: stable-v1.0
              minVersion: 1.0.0
              maxVersion: 1.0.0
        - name: limitador-operator
          defaultChannel: stable
          channels:
            - name: stable
              minVersion: 1.3.0
              maxVersion: 1.3.0
        - name: authorino-operator
          defaultChannel: stable
          channels:
            - name: stable
              minVersion: 1.3.0
              maxVersion: 1.3.0
        - name: dns-operator
          defaultChannel: stable
          channels:
            - name: stable
              minVersion: 1.3.0
              maxVersion: 1.3.0

  # Block unnecessary RHOAI images to reduce mirror size
  # Only mirror images for enabled components
  blockedimages:
    # Dashboard images (only if dashboard is Removed)
    - name: registry.redhat.io/rhoai/odh-dashboard-rhel8
    - name: registry.redhat.io/rhoai/odh-dashboard-rhel9
    # CodeFlare images (only if codeflare is Removed)
    - name: registry.redhat.io/rhoai/odh-codeflare-operator-rhel9
    - name: registry.redhat.io/rhoai/odh-codeflare-operator-rhel8
    # Data Science Pipelines (only if datasciencepipelines is Removed)
    - name: registry.redhat.io/rhoai/odh-data-science-pipelines-operator-controller-rhel8
    - name: registry.redhat.io/rhoai/odh-data-science-pipelines-operator-controller-rhel9
    - name: registry.redhat.io/rhoai/odh-data-science-pipelines-argo-argoexec-rhel9
    - name: registry.redhat.io/rhoai/odh-data-science-pipelines-argo-workflowcontroller-rhel9
    - name: registry.redhat.io/rhoai/odh-data-science-pipelines-argo-argoexec-rhel8
    - name: registry.redhat.io/rhoai/odh-data-science-pipelines-argo-workflowcontroller-rhel8
    # Kueue images (only if kueue is Removed)
    - name: registry.redhat.io/rhoai/odh-kueue-controller-rhel8
    - name: registry.redhat.io/rhoai/odh-kueue-controller-rhel9
    # ModelMesh images (only if modelmeshserving is Removed)
    - name: registry.redhat.io/rhoai/odh-modelmesh-serving-controller-rhel8
